# App
ENVIRONMENT=development

# PostgreSQL (navixa_db)
POSTGRES_USER=navixa
POSTGRES_DB=navixa_db
# DATABASE_URL: set directly for local dev, or omit once SECRET_PROVIDER
# below is pointed at a vault holding "navixa-database-url".
DATABASE_URL=postgresql+psycopg://navixa:changeme@localhost:5432/navixa_db

# Redis - Celery broker/result backend only, not app data
REDIS_URL=redis://localhost:6379/0

# JWT
# JWT_SECRET_KEY: set directly for local dev, or source from vault secret
# "navixa-jwt-secret-key".
JWT_SECRET_KEY=changeme-dev-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# AWS (Discover)
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=

# NAVIXA InsightAI providers (Section 15) - never hardcode a real key here.
# Each can instead be sourced from a vault secret once SECRET_PROVIDER is
# set: navixa-anthropic-api-key, navixa-openai-api-key,
# navixa-azure-openai-api-key, navixa-gemini-api-key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Entra ID SSO/OIDC (Section 6) - unset keeps local JWT auth as the only
# login path. ENTRA_CLIENT_SECRET may be sourced from vault secret
# "navixa-entra-client-secret" instead of being set here.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/entra/callback
FRONTEND_SSO_REDIRECT_URL=http://localhost:5173/sso/callback

# Cloud auth mode (Section 8a): "delegated" or "app_only"
CLOUD_AUTH_MODE=app_only

AWS_AUDIT_ROLE_NAME=NavixaAuditRole
AWS_AUDIT_EXTERNAL_ID=
AZURE_FEDERATION_TENANT_ID=
AZURE_FEDERATION_CLIENT_ID=
AZURE_FEDERATION_CLIENT_SECRET=
GCP_AUDIT_SERVICE_ACCOUNT=
OCI_SESSION_TOKEN_PATH=
OCI_CONFIG_PROFILE=DEFAULT

# Secret Manager (Section 7). "env" (default) reads secrets from this file /
# real environment variables - fine for local dev. Set to
# "azure_key_vault" or "aws_secrets_manager" in production so real secrets
# never live in a checked-out .env file; only fields present in the vault
# get overridden, so migration can happen incrementally. Secret names
# expected in the vault:
#   navixa-jwt-secret-key, navixa-database-url,
#   navixa-entra-client-secret, navixa-anthropic-api-key,
#   navixa-openai-api-key, navixa-azure-openai-api-key,
#   navixa-gemini-api-key, navixa-azure-federation-client-secret,
#   navixa-aws-audit-external-id
SECRET_PROVIDER=env
AWS_SECRETS_MANAGER_REGION=us-east-1
AZURE_KEY_VAULT_URL=

# Celery worker scaling
CELERY_WORKER_CONCURRENCY=4
