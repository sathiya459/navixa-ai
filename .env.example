# App
ENVIRONMENT=development

# PostgreSQL (navixa_db)
POSTGRES_USER=navixa
POSTGRES_PASSWORD=navixa
POSTGRES_DB=navixa_db
DATABASE_URL=postgresql+psycopg://navixa:navixa@postgres:5432/navixa_db

# Redis (navixa_cache)
REDIS_URL=redis://redis:6379/0

# Neo4j (navixa_graph) - used from Phase 3 onward
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# JWT
JWT_SECRET_KEY=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# AWS (Discover) - temporary credentials via AssumeRole only, never long-lived keys
AWS_DEFAULT_REGION=us-east-1

# AI providers (Phase 4) - set only the ones in use, never commit real keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Bedrock uses the AWS credential chain above, not a separate key
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Entra ID SSO (Phase 5) - unset keeps local JWT auth as the only login path
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/entra/callback

# Cloud federation (Phase 5, Section 8) - unset falls back to dev stubs
AWS_AUDIT_ROLE_NAME=NavixaAuditRole
AWS_AUDIT_EXTERNAL_ID=

AZURE_FEDERATION_TENANT_ID=
AZURE_FEDERATION_CLIENT_ID=
AZURE_FEDERATION_CLIENT_SECRET=

GCP_AUDIT_SERVICE_ACCOUNT=

OCI_SESSION_TOKEN_PATH=
OCI_CONFIG_PROFILE=DEFAULT

# Secret Manager (Phase 5, Section 7) - "env" (default), "aws_secrets_manager", or "azure_key_vault"
SECRET_PROVIDER=env
AWS_SECRETS_MANAGER_REGION=us-east-1
AZURE_KEY_VAULT_URL=

# Celery worker scaling (Phase 5) - per-process concurrency; scale workers
# horizontally with `docker compose up --scale celery_worker=N`
CELERY_WORKER_CONCURRENCY=4
