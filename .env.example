# App
ENVIRONMENT=development

# PostgreSQL (navixa_db)
POSTGRES_USER=navixa
POSTGRES_PASSWORD=navixa
POSTGRES_DB=navixa_db
DATABASE_URL=postgresql+psycopg://navixa:navixa@postgres:5432/navixa_db

# Redis (navixa_cache)
REDIS_URL=redis://redis:6379/0

# Neo4j (navixa_graph) - used from Phase 3 onward
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# JWT
JWT_SECRET_KEY=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# AWS (Discover) - temporary credentials via AssumeRole only, never long-lived keys
AWS_DEFAULT_REGION=us-east-1

# AI providers (Phase 4) - set only the ones in use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
GEMINI_API_KEY=
